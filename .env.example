# OpenRouter — unified API for GPT-4, Claude, Gemini, Llama, DeepSeek, Qwen
# Get a free key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Database (auto-created on first run)
DATABASE_URL=sqlite:///./data/myco.db

# Optional: Redis for future distributed features (not required)
REDIS_URL=redis://localhost:6379/0

# Kernel economics
KERNEL_TAX_RATE=0.15

# Skill Commons (optional — leave empty to disable)
COMMONS_URL=

# Stripe (optional — required for organism funding via credit card)
# Get keys at: https://dashboard.stripe.com/apikeys
# Get webhook secret at: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BASE_URL=http://localhost:8000
